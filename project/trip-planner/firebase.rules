rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trips/{tripId} {
      allow read: if true; // adjust for your auth
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      match /days/{dayId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId;
      }
    }
  }
}